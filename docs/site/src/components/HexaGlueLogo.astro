---
// HexaGlue Logo - Hexagon with gradient
---

<svg
	width="140"
	height="32"
	viewBox="0 0 140 32"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	{...Astro.props}
	class:list={[Astro.props.class]}
>
	<defs>
		<linearGradient id="hexaglue-logo-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
			<stop offset="0%" style="stop-color:#3245FF" />
			<stop offset="100%" style="stop-color:#BC52EE" />
		</linearGradient>
	</defs>
	<!-- Hexagon icon -->
	<path
		d="M16 2 L28 9 L28 23 L16 30 L4 23 L4 9 Z"
		fill="none"
		stroke="url(#hexaglue-logo-gradient)"
		stroke-width="2"
		stroke-linejoin="round"
	/>
	<path
		d="M16 8 L24 12.5 L24 21.5 L16 26 L8 21.5 L8 12.5 Z"
		fill="url(#hexaglue-logo-gradient)"
		opacity="0.3"
	/>
	<circle cx="16" cy="16" r="4" fill="url(#hexaglue-logo-gradient)" />
	<circle cx="16" cy="16" r="2" fill="#0D0F14" />
	<!-- Text "HexaGlue" -->
	<text
		x="36"
		y="22"
		fill="white"
		font-family="Degular, system-ui, sans-serif"
		font-size="16"
		font-weight="380"
	>
		HexaGlue
	</text>
</svg>
