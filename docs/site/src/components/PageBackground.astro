---
interface Props {
	section: 'ressources' | 'entreprise';
}

const { section } = Astro.props;
---

<div class="page-background">
	<div class:list={['glow', section === 'ressources' ? 'glow-green' : 'glow-purple']}></div>
	<div class:list={['glow-secondary', section === 'ressources' ? 'glow-green' : 'glow-purple']}></div>
</div>

<style>
	.page-background {
		position: absolute;
		top: -200px;
		left: -50%;
		right: -50%;
		bottom: -200px;
		pointer-events: none;
		z-index: -1;
	}

	.glow {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) rotate(-12deg);
		width: 120%;
		height: 500px;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.2;
	}

	.glow-secondary {
		position: absolute;
		top: 20%;
		right: -10%;
		transform: rotate(8deg);
		width: 70%;
		height: 400px;
		border-radius: 50%;
		filter: blur(100px);
		opacity: 0.12;
	}

	.glow-green {
		background: linear-gradient(135deg, #40DEBF 0%, #334BA9 100%);
	}

	.glow-purple {
		background: linear-gradient(135deg, #BC52EE 0%, #3245FF 100%);
	}
</style>
