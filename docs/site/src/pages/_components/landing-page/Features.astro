---
import SectionCopy from '../SectionCopy.astro';
import FeatureCard from './feature-cards/FeatureCard.astro';
import ClassificationCard from './feature-cards/ClassificationCard.astro';
import JPAGenerationCard from './feature-cards/JPAGenerationCard.astro';
import LivingDocCard from './feature-cards/LivingDocCard.astro';
import AuditCard from './feature-cards/AuditCard.astro';
---

<section
	class="mt-20 md:mt-24 lg:mt-28 xl:mt-36 relative w-full max-w-screen-xl mx-auto px-4 sm:px-8"
>
	<SectionCopy
		label="Tout ce dont vous avez besoin"
		title="Une Couverture Fonctionnelle Complète"
		description="HexaGlue transforme le code métier en infrastructure prête pour la production."
	/>

	<div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-fr">
		<!-- Row 1 -->
		<ClassificationCard />
		<JPAGenerationCard />

		<!-- Row 2 -->
		<LivingDocCard />

		<AuditCard />

		<FeatureCard
			icon="ri/shield-check-line"
			title="Validation au Build-time"
			description="Capture les violations d'architecture avant les déploiements avec l'intégration d'un plugin Maven."
		/>

		<!-- Row 3 -->
		<FeatureCard
			icon="hexaglue/hexagon"
			title="Clean Architecture"
			description="Supporte les patterns de la Clean architecture avec séparations des préoccupations."
		/>

		<FeatureCard
			icon="hexaglue/pipeline"
			title="Détection des Ports et Adapteurs"
			description="Identifie automatiquement les ports driving et driven de votre architecture hexagonale."
		/>

		<FeatureCard
			icon="hexaglue/domain"
			title="Plugin Maven"
			description="Intégration simple à l'aide d'un plugin Maven pour générer, valider et auditer votre application."
		/>

		<FeatureCard
			icon="ri/dashboard-line"
			title="Architecture Extensible"
			description="Son système de plugin permet de construire des générateurs et des validations pour vos besoins spécifiques."
		/>
	</div>
</section>
