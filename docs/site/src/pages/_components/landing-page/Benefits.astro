---
import GemIcon from '~/components/GemIcon.astro';
import IntroPoint from '../IntroPoint.astro';
---

<section class="mt-20 sm:mt-36 xs:p-6 mx-auto w-full max-w-screen-xl space-y-8 p-4 sm:p-8">
	<div class="space-y-1">
		<span class="bg-clip-text text-transparent bg-orange-yellow-gradient font-semibold">
			Ce que Produit HexaGlue
		</span>
		<h2
			class="max-w-screen-lg text-balance text-2xl font-light font-heading md:text-3xl xl:text-4xl md:leading-tight"
		>
			Des résultats <strong>concrets</strong> et <strong>mesurables</strong>
		</h2>
	</div>

	<div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12 lg:grid-cols-3">
		<IntroPoint title="Compile-time">
			<GemIcon slot="icon" icon="ri/timer-flash-line" gradient="blue-green" />
			<Fragment slot="description">
				Feedback architectural en CI : l'architecture devient un signal, pas un document statique.
			</Fragment>
		</IntroPoint>

		<IntroPoint title="Déterministe">
			<GemIcon slot="icon" icon="ri/checkbox-circle-line" gradient="red-pink" />
			<Fragment slot="description">
				Classification traçable : ce qui est ambigu est signalé, jamais supposé.
			</Fragment>
		</IntroPoint>

		<IntroPoint title="At Scale">
			<GemIcon slot="icon" icon="ri/stack-line" gradient="orange-yellow" />
			<Fragment slot="description">
				Standardisation des patterns et réduction de la dette d'intégration à l'échelle de
				l'entreprise.
			</Fragment>
		</IntroPoint>
	</div>
</section>

<style>
	h2 {
		font-variation-settings:
			'wght' 290,
			'wdth' 490 !important;
	}

	h2 strong {
		font-variation-settings:
			'wght' 475,
			'wdth' 490;
	}
</style>
