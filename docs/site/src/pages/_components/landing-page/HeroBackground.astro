---
/**
 * Hero background with hexagonal pattern and gradient overlay.
 */
import { Image } from 'astro:assets';
import heroBackground from './_assets/HeroBackground.svg';
---

<div class="hero-bg-container">
	<Image
		src={heroBackground}
		alt=""
		class="hero-bg-image"
		loading="eager"
		decoding="async"
	/>
	<div class="hero-bg-fade"></div>
</div>

<style>
	.hero-bg-container {
		position: absolute;
		inset: 0;
		bottom: -200px;
		z-index: -50;
		overflow: visible;
		pointer-events: none;
	}

	.hero-bg-image {
		position: absolute;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 150%;
		max-width: none;
		height: auto;
		min-height: 140%;
		object-fit: cover;
		opacity: 1;
	}

	.hero-bg-fade {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 300px;
		background: linear-gradient(to bottom, transparent 0%, #0d0f14 100%);
		pointer-events: none;
	}

	@media (max-width: 768px) {
		.hero-bg-image {
			width: 200%;
			top: -10%;
		}
	}
</style>
